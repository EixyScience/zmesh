#!/bin/sh
set -eu

TOOLBASE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

find_tool() {
  name="$1"
  if [ -f "$TOOLBASE/tools/$name" ]; then
    echo "$TOOLBASE/tools/$name"
    return 0
  fi
  if [ -f "$TOOLBASE/$name" ]; then
    echo "$TOOLBASE/$name"
    return 0
  fi
  return 1
}

help() {
cat <<'EOF'
scalefs - ScaleFS local filesystem body helper

USAGE
  scalefs <command> [options]

COMMANDS
  init        Create skeleton for a scalefs body in the current directory
  add         Create a new scalefs body under a registered root (name + shortid)
  list        List scalefs bodies under registered roots
  remove      Remove a scalefs body (best-effort; may refuse if mounted)
  mount       Mount scalefs main (ZFS if available; otherwise no-op/placeholder)
  umount      Unmount scalefs main (ZFS if available; otherwise no-op/placeholder)
  snapshot    Create a snapshot (ZFS-only for now)
  sync        Sync snapshot to peer (ZFS-only placeholder for now)
  help        Show this help

OPTIONS (typical)
  -h, --help              Show help
  -r, --root NAME         Root alias/name (for add/list/remove)
  -n, --name NAME         Human name (normalized); used with add
  -i, --id ID             Full scalefs id (name.shortid); used with remove/mount/umount
  -p, --path PATH         Explicit path (override root resolution) when applicable

EXAMPLES
  # Create a scalefs body under a root (interactive root selection if omitted)
  scalefs add -r test -n DemoCell

  # List scalefs bodies under all roots
  scalefs list

  # Remove a scalefs body by id
  scalefs remove -i democell.17ded8
EOF
}

run() {
  f="$1"; shift
  path="$(find_tool "$f")" || { echo "missing tool: $f (searched: $TOOLBASE/tools and $TOOLBASE)"; exit 127; }
  exec "$path" "$@"
}

[ $# -ge 1 ] || { help; exit 0; }
case "$1" in
  -h|--help|help) help; exit 0;;
esac

cmd="$1"; shift || true
case "$cmd" in
  init)     run "scalefs-init.sh" "$@";;
  mount)    run "scalefs-mount.sh" "$@";;
  umount)   run "scalefs-umount.sh" "$@";;
  add)      run "add-scalefs.sh" "$@";;
  list)     run "list-scalefs.sh" "$@";;
  remove)   run "remove-scalefs.sh" "$@";;

  clone)    run "clone-scalefs.sh" "$@";;
  move)     run "move-scalefs.sh" "$@";;
  snapshot) run "snapshot-scalefs.sh" "$@";;
  sync)     run "sync-scalefs.sh" "$@";;

  *) help; exit 2;;
esac