#!/bin/sh
set -eu

TOOLBASE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

find_tool() {
  name="$1"
  if [ -f "$TOOLBASE/tools/$name" ]; then
    echo "$TOOLBASE/tools/$name"
    return 0
  fi
  if [ -f "$TOOLBASE/$name" ]; then
    echo "$TOOLBASE/$name"
    return 0
  fi
  return 1
}

help() {
cat <<'EOF'
scalefs - ScaleFS local filesystem body helper

USAGE
  scalefs <command> [options]

COMMANDS
  init       Create skeleton for a scalefs body (in current directory)
  add        Create a new scalefs body under a registered root
  list       List scalefs bodies under registered roots
  remove     Remove a scalefs body (best-effort; may refuse if mounted)
  manifest   Emit a manifest of main/ (file list + metadata)
  clean      Cleanup runtime/state artifacts (safe by default)
  mount      Mount scalefs main (ZFS if available; otherwise placeholder)
  umount     Unmount scalefs main (ZFS if available; otherwise placeholder)
  snapshot   Create a snapshot (ZFS-only for now)
  sync       Sync snapshot to peer (ZFS-only placeholder for now)
  help       Show this help

OPTIONS (common)
  -h, --help   Show help

COMMAND + OPTIONS + EXAMPLES
  scalefs add -r, --root ROOT  -n, --name NAME
    EX: scalefs add -r test -n DemoCell
    EX: ROOT=test NAME=DemoCell scalefs add              (non-interactive env)

  scalefs remove -i, --id ID
    EX: scalefs remove -i democell.17ded8
    EX: ID=democell.17ded8 scalefs remove               (non-interactive env)

  scalefs manifest -p, --path DIR | -i, --id ID  [-o, --out FILE] [--stdout] [--hash ALG]
    EX: scalefs manifest -i democell.17ded8 --stdout
    EX: scalefs manifest -p /mnt/zmtest/scalefsroot/democell.17ded8 -o ./m.txt

  scalefs clean -p, --path DIR | -i, --id ID  [--dry-run] [--force] [--zfs]
    EX: scalefs clean -i democell.17ded8 --dry-run
    EX: scalefs clean -i democell.17ded8 --force --zfs

NOTES
  - For detailed help per command:
      scalefs <command> --help
EOF
}

run() {
  f="$1"; shift
  path="$(find_tool "$f")" || { echo "missing tool: $f (searched: $TOOLBASE/tools and $TOOLBASE)"; exit 127; }
  exec "$path" "$@"
}

[ $# -ge 1 ] || { help; exit 0; }
case "$1" in
  -h|--help|help) help; exit 0;;
esac

cmd="$1"; shift || true
case "$cmd" in
  init)     run "scalefs-init.sh" "$@";;

  add)      run "add-scalefs.sh" "$@";;
  list)     run "list-scalefs.sh" "$@";;
  remove)   run "remove-scalefs.sh" "$@";;

  manifest) run "manifest-scalefs.sh" "$@";;
  clean)    run "clean-scalefs.sh" "$@";;

  mount)    run "scalefs-mount.sh" "$@";;
  umount)   run "scalefs-umount.sh" "$@";;

  clone)    run "clone-scalefs.sh" "$@";;
  move)     run "move-scalefs.sh" "$@";;
  snapshot) run "snapshot-scalefs.sh" "$@";;
  sync)     run "sync-scalefs.sh" "$@";;

  *) help; exit 2;;
esac