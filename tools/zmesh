#!/bin/sh
set -eu

TOOLBASE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

# tools/優先。無ければ直下。
find_tool() {
  name="$1"
  if [ -f "$TOOLBASE/tools/$name" ]; then
    echo "$TOOLBASE/tools/$name"
    return 0
  fi
  if [ -f "$TOOLBASE/$name" ]; then
    echo "$TOOLBASE/$name"
    return 0
  fi
  return 1
}

help() {
cat <<'EOF'
zmesh - orchestrator/agent helper for ScaleFS

USAGE
  zmesh <command> [options]

COMMANDS
  init        Initialize zmesh config skeleton (creates/updates zmesh.conf and zmesh.d/)
  start       Start zmesh agent (foreground)
  stop        Stop zmesh agent (best-effort)
  status      Show local status / quick diagnostics
  doctor      Run environment checks (paths, permissions, zfs availability)
  root        Manage ScaleFS roots (add/list/remove)
  scalefs     Proxy to scalefs tool (run "zmesh scalefs help" for details)
  virtualpath Manage virtual path rules (add/list/remove/doctor/apply)
  help        Show this help

NOTES
  - To see scalefs help from zmesh:
      zmesh scalefs help

  - To see virtualpath help:
      zmesh virtualpath help

EXAMPLES
  # Initialize zmesh (interactive)
  zmesh init

  # Start agent using a specific config file (example)
  zmesh start -c ./zmesh.conf

  # Add a new ScaleFS root location
  zmesh root add

  # Apply virtualpath rules into /vroot, also cleanup stale links
  zmesh virtualpath apply --root /vroot --clean --yes
EOF
}

run() {
  f="$1"; shift
  path="$(find_tool "$f")" || { echo "missing tool: $f (searched: $TOOLBASE/tools and $TOOLBASE)"; exit 127; }
  exec "$path" "$@"
}

[ $# -ge 1 ] || { help; exit 0; }
case "${1:-}" in
  -h|--help|help) help; exit 0;;
esac

cmd="$1"; shift || true

case "$cmd" in
  init)   run "zmesh-init.sh" "$@";;
  start)  run "zmesh-start.sh" "$@";;
  stop)   run "zmesh-stop.sh" "$@";;
  status) run "zmesh-status.sh" "$@";;
  doctor) run "doctor.sh" "$@";;

  root)
    [ $# -ge 1 ] || { help; exit 2; }
    sub="$1"; shift || true
    case "$sub" in
      add)    run "add-root.sh" "$@";;
      list)   run "list-root.sh" "$@";;
      remove|rm) run "remove-root.sh" "$@";;
      help|-h|--help) help; exit 0;;
      *) help; exit 2;;
    esac
    ;;

  scalefs)
    spath="$(find_tool "scalefs")" || { echo "missing tool: scalefs"; exit 127; }
    exec "$spath" "$@"
    ;;

  virtualpath)
    sub="${1:-help}"; shift || true
    case "$sub" in
      add)      run "add-virtualpath.sh" "$@";;
      list)     run "list-virtualpath.sh" "$@";;
      remove|rm)run "remove-virtualpath.sh" "$@";;
      doctor)   run "doctor-virtualpath.sh" "$@";;

      apply)
        # Preferred name: tools/virtualpath-apply.sh
        # (Back-compat: tools/apply-virtualpath.sh も探す)
        if find_tool "virtualpath-apply.sh" >/dev/null 2>&1; then
          run "virtualpath-apply.sh" "$@"
        else
          run "apply-virtualpath.sh" "$@"
        fi
        ;;

      help|-h|--help)
        cat <<'EOF'
zmesh virtualpath - manage virtual path rules

USAGE
  zmesh virtualpath <subcommand> [options]

SUBCOMMANDS
  add         Add a rule file under virtualpath.d/
  list        List rules
  remove      Remove a rule
  doctor      Diagnostics for virtualpath config
  apply       Apply rules into a vroot (and write manifest; optional --clean)

APPLY EXAMPLES
  zmesh virtualpath apply --root /vroot
  zmesh virtualpath apply --root /vroot --clean --yes
  ZCONF_DIR=/usr/local/etc/zmesh zmesh virtualpath apply --root /vroot --clean --yes
EOF
        exit 0
        ;;

      *)
        echo "Usage: zmesh virtualpath {add|list|remove|doctor|apply|help}"
        exit 2
        ;;
    esac
    ;;

  *)
    help
    exit 2
    ;;
esac