#!/bin/sh
set -eu

# repo root auto-detect:
# - if this script is in repo root:  <root>/zmesh
# - if this script is in tools/:     <root>/tools/zmesh
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if [ -d "$SELF_DIR/tools" ]; then
  REPO_ROOT="$SELF_DIR"
elif [ -d "$SELF_DIR/../tools" ]; then
  REPO_ROOT=$(CDPATH= cd -- "$SELF_DIR/.." && pwd)
else
  REPO_ROOT="$SELF_DIR"
fi

# TOOLS_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# . "$TOOLS_DIR/common.sh"
. tools/common.sh

find_tool() {
  name="$1"
  if [ -f "$REPO_ROOT/tools/$name" ]; then echo "$REPO_ROOT/tools/$name"; return 0; fi
  if [ -f "$REPO_ROOT/$name" ]; then echo "$REPO_ROOT/$name"; return 0; fi
  return 1
}

help() {
cat <<'EOF'
zmesh - orchestrator/agent helper for ScaleFS

USAGE
  zmesh <command> [args...]

COMMANDS
  init            Initialize zmesh config skeleton (zmesh.conf and zmesh.d/)
  start           Start zmesh agent (foreground)
  stop            Stop zmesh agent (best-effort)
  status          Show local status / quick diagnostics
  doctor          Run environment checks
  root add        Register a scalefs root
  root list       List registered roots
  root remove     Remove a registered root
  list            Shortcut for: zmesh scalefs list
  scalefs         Proxy to scalefs tool (use: zmesh scalefs help)
  help            Show this help

COMMON OPTIONS
  -h, --help      Show help

COMMAND HELP
  zmesh <command> --help

EXAMPLES
  zmesh init
  zmesh start -c ./zmesh.conf
  zmesh status
  zmesh root add -a default -p "$HOME/scalefs"
  zmesh list
  zmesh scalefs help
EOF
}

run() {
  f="$1"; shift
  path="$(find_tool "$f")" || { echo "missing tool: $f (searched: $REPO_ROOT/tools and $REPO_ROOT)"; exit 127; }
  exec "$path" "$@"
}

[ $# -ge 1 ] || { help; exit 0; }
case "$1" in
  -h|--help|help) help; exit 0;;
esac

cmd="$1"; shift || true

case "$cmd" in
  init)   run "zmesh-init.sh" "$@";;
  start)  run "zmesh-start.sh" "$@";;
  stop)   run "zmesh-stop.sh" "$@";;
  status) run "zmesh-status.sh" "$@";;
  doctor) run "doctor.sh" "$@";;

  root)
    sub="${1:-}"; [ -n "$sub" ] || { help; exit 2; }
    shift || true
    case "$sub" in
      add)    run "add-root.sh" "$@";;
      list)   run "list-root.sh" "$@";;
      remove|rm) run "remove-root.sh" "$@";;
      *) help; exit 2;;
    esac
    ;;

  list)
    # convenience
    spath="$(find_tool "scalefs")" || { echo "missing tool: scalefs"; exit 127; }
    exec "$spath" list "$@"
    ;;

  scalefs)
    spath="$(find_tool "scalefs")" || { echo "missing tool: scalefs"; exit 127; }
    exec "$spath" "$@"
    ;;

  *) help; exit 2;;
esac